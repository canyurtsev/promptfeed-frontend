// ============================================
// PAYMENT BACKEND CLASS
// ============================================
class PaymentBackend {
    constructor() {
        this.config = PAYMENT_CONFIG;
        this.products = PAYMENT_CONFIG.useMockData ? [...MOCK_PRODUCTS] : [];
        this.transactions = PAYMENT_CONFIG.useMockData ? [...MOCK_TRANSACTIONS] : [];
        this.subscriptions = PAYMENT_CONFIG.useMockData ? [...MOCK_SUBSCRIPTIONS] : [];
        this.bounties = PAYMENT_CONFIG.useMockData ? [...MOCK_BOUNTIES] : [];
        this.wallets = PAYMENT_CONFIG.useMockData ? { ...MOCK_WALLETS } : {};
    }

    // ============================================
    // CONFIGURATION METHODS
    // ============================================
    setMode(mode) {
        this.config.mode = mode;
        this.config.useMockData = (mode === 'demo');
        if (mode === 'production') {
            this.resetProductionData();
        } else {
            this.loadMockData();
        }
    }

    resetProductionData() {
        this.products = [];
        this.transactions = [];
        this.subscriptions = [];
        this.bounties = [];
        this.wallets = {};
    }

    loadMockData() {
        this.products = [...MOCK_PRODUCTS];
        this.transactions = [...MOCK_TRANSACTIONS];
        this.subscriptions = [...MOCK_SUBSCRIPTIONS];
        this.bounties = [...MOCK_BOUNTIES];
        this.wallets = { ...MOCK_WALLETS };
    }

    // ============================================
    // PRODUCT/MARKETPLACE METHODS
    // ============================================
    getProducts(filters = {}) {
        let products = [...this.products];

        // Filter by category
        if (filters.category) {
            products = products.filter(p => p.category === filters.category);
        }

        // Filter by price range
        if (filters.minPrice !== undefined) {
            products = products.filter(p => p.price >= filters.minPrice);
        }
        if (filters.maxPrice !== undefined) {
            products = products.filter(p => p.price <= filters.maxPrice);
        }

        // Filter by tags
        if (filters.tags && filters.tags.length > 0) {
            products = products.filter(p =>
                filters.tags.some(tag => p.tags.includes(tag))
            );
        }

        // Search by title/description
        if (filters.search) {
            const searchLower = filters.search.toLowerCase();
            products = products.filter(p =>
                p.title.toLowerCase().includes(searchLower) ||
                p.description.toLowerCase().includes(searchLower)
            );
        }

        // Sort
        if (filters.sortBy) {
            switch (filters.sortBy) {
                case 'price-asc':
                    products.sort((a, b) => a.price - b.price);
                    break;
                case 'price-desc':
                    products.sort((a, b) => b.price - a.price);
                    break;
                case 'popular':
                    products.sort((a, b) => b.salesCount - a.salesCount);
                    break;
                case 'rating':
                    products.sort((a, b) => b.rating - a.rating);
                    break;
                case 'newest':
                    products.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
                    break;
            }
        }

        return products;
    }

    getProductById(productId) {
        return this.products.find(p => p.id === productId);
    }

    getFeaturedProducts() {
        return this.products.filter(p => p.featured);
    }

    createProduct(productData) {
        const newProduct = {
            id: `prod_${Date.now()}`,
            ...productData,
            salesCount: 0,
            rating: 0,
            reviewCount: 0,
            createdAt: new Date().toISOString()
        };
        this.products.push(newProduct);
        return newProduct;
    }

    // ============================================
    // TRANSACTION METHODS
    // ============================================
    createTransaction(transactionData) {
        const product = this.getProductById(transactionData.productId);
        if (!product) {
            throw new Error('Product not found');
        }

        const platformFee = product.price * this.config.platformFee;
        const sellerEarnings = product.price - platformFee;

        const transaction = {
            id: `txn_${Date.now()}`,
            ...transactionData,
            amount: product.price,
            platformFee: platformFee,
            sellerEarnings: sellerEarnings,
            currency: this.config.currency,
            status: 'pending',
            timestamp: new Date().toISOString()
        };

        this.transactions.push(transaction);
        return transaction;
    }

    completeTransaction(transactionId) {
        const transaction = this.transactions.find(t => t.id === transactionId);
        if (!transaction) {
            throw new Error('Transaction not found');
        }

        transaction.status = 'completed';

        // Update product sales count
        const product = this.getProductById(transaction.productId);
        if (product) {
            product.salesCount++;
        }

        // Update seller wallet
        this.addToWallet(transaction.sellerId, transaction.sellerEarnings);

        return transaction;
    }

    getUserTransactions(userId, type = 'all') {
        let transactions = [...this.transactions];

        if (type === 'purchases') {
            transactions = transactions.filter(t => t.buyerId === userId);
        } else if (type === 'sales') {
            transactions = transactions.filter(t => t.sellerId === userId);
        } else {
            transactions = transactions.filter(t =>
                t.buyerId === userId || t.sellerId === userId
            );
        }

        return transactions.sort((a, b) =>
            new Date(b.timestamp) - new Date(a.timestamp)
        );
    }

    // ============================================
    // SUBSCRIPTION METHODS
    // ============================================
    getSubscriptionPlans() {
        return SUBSCRIPTION_PLANS;
    }

    getUserSubscription(userId) {
        return this.subscriptions.find(s => s.userId === userId && s.status === 'active');
    }

    createSubscription(userId, planId) {
        const plan = SUBSCRIPTION_PLANS[planId];
        if (!plan) {
            throw new Error('Invalid plan');
        }

        // Cancel existing subscription
        const existing = this.getUserSubscription(userId);
        if (existing) {
            existing.status = 'cancelled';
        }

        const subscription = {
            id: `sub_${Date.now()}`,
            userId: userId,
            plan: planId,
            status: 'active',
            startDate: new Date().toISOString(),
            currentPeriodStart: new Date().toISOString(),
            currentPeriodEnd: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(),
            cancelAtPeriodEnd: false,
            price: plan.price,
            currency: this.config.currency
        };

        this.subscriptions.push(subscription);
        return subscription;
    }

    cancelSubscription(subscriptionId) {
        const subscription = this.subscriptions.find(s => s.id === subscriptionId);
        if (!subscription) {
            throw new Error('Subscription not found');
        }

        subscription.cancelAtPeriodEnd = true;
        return subscription;
    }

    // ============================================
    // BOUNTY METHODS
    // ============================================
    getBounties(filters = {}) {
        let bounties = [...this.bounties];

        if (filters.status) {
            bounties = bounties.filter(b => b.status === filters.status);
        }

        if (filters.category) {
            bounties = bounties.filter(b => b.category === filters.category);
        }

        if (filters.sortBy === 'amount') {
            bounties.sort((a, b) => b.amount - a.amount);
        } else if (filters.sortBy === 'deadline') {
            bounties.sort((a, b) => new Date(a.deadline) - new Date(b.deadline));
        } else {
            bounties.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
        }

        return bounties;
    }

    getBountyById(bountyId) {
        return this.bounties.find(b => b.id === bountyId);
    }

    createBounty(bountyData) {
        const bounty = {
            id: `bounty_${Date.now()}`,
            ...bountyData,
            status: 'open',
            createdAt: new Date().toISOString(),
            submissions: [],
            viewCount: 0
        };

        this.bounties.push(bounty);
        return bounty;
    }

    submitBountyProposal(bountyId, userId, userName) {
        const bounty = this.getBountyById(bountyId);
        if (!bounty) {
            throw new Error('Bounty not found');
        }

        const submission = {
            id: `sub_${Date.now()}`,
            userId: userId,
            userName: userName,
            submittedAt: new Date().toISOString(),
            status: 'pending'
        };

        bounty.submissions.push(submission);
        bounty.status = 'in-progress';
        return submission;
    }

    awardBounty(bountyId, submissionId) {
        const bounty = this.getBountyById(bountyId);
        if (!bounty) {
            throw new Error('Bounty not found');
        }

        const submission = bounty.submissions.find(s => s.id === submissionId);
        if (!submission) {
            throw new Error('Submission not found');
        }

        submission.status = 'accepted';
        bounty.status = 'completed';

        // Transfer bounty amount to winner
        this.addToWallet(submission.userId, bounty.amount);

        return bounty;
    }

    // ============================================
    // WALLET METHODS
    // ============================================
    getWallet(userId) {
        if (!this.wallets[userId]) {
            this.wallets[userId] = {
                userId: userId,
                balance: 0,
                totalEarnings: 0,
                totalSpent: 0,
                pendingPayouts: 0,
                lifetimePayouts: 0,
                payoutMethod: null,
                payoutDetails: null,
                currency: this.config.currency
            };
        }
        return this.wallets[userId];
    }

    addToWallet(userId, amount) {
        const wallet = this.getWallet(userId);
        wallet.balance += amount;
        wallet.totalEarnings += amount;
        return wallet;
    }

    deductFromWallet(userId, amount) {
        const wallet = this.getWallet(userId);
        if (wallet.balance < amount) {
            throw new Error('Insufficient balance');
        }
        wallet.balance -= amount;
        wallet.totalSpent += amount;
        return wallet;
    }

    requestPayout(userId, amount) {
        const wallet = this.getWallet(userId);

        if (amount < this.config.payoutThreshold) {
            throw new Error(`Minimum payout amount is ${this.config.currency} ${this.config.payoutThreshold}`);
        }

        if (wallet.balance < amount) {
            throw new Error('Insufficient balance');
        }

        wallet.balance -= amount;
        wallet.pendingPayouts += amount;

        return {
            success: true,
            message: 'Payout request submitted',
            amount: amount,
            estimatedArrival: '3-5 business days'
        };
    }

    // ============================================
    // ANALYTICS METHODS
    // ============================================
    getSellerAnalytics(userId) {
        const sales = this.transactions.filter(t =>
            t.sellerId === userId && t.status === 'completed'
        );

        const totalRevenue = sales.reduce((sum, t) => sum + t.sellerEarnings, 0);
        const totalSales = sales.length;

        // Group by product
        const productSales = {};
        sales.forEach(sale => {
            if (!productSales[sale.productId]) {
                productSales[sale.productId] = {
                    productTitle: sale.productTitle,
                    count: 0,
                    revenue: 0
                };
            }
            productSales[sale.productId].count++;
            productSales[sale.productId].revenue += sale.sellerEarnings;
        });

        // Sales over time (last 30 days)
        const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
        const recentSales = sales.filter(s => new Date(s.timestamp) > thirtyDaysAgo);

        return {
            totalRevenue,
            totalSales,
            averageOrderValue: totalSales > 0 ? totalRevenue / totalSales : 0,
            productSales: Object.values(productSales),
            recentSales: recentSales.length,
            wallet: this.getWallet(userId)
        };
    }
}

// ============================================
// INITIALIZE GLOBAL INSTANCE
// ============================================
if (typeof window !== 'undefined') {
    window.paymentBackend = new PaymentBackend();
    console.log('💳 Payment Backend initialized in', PAYMENT_CONFIG.mode, 'mode');
}
