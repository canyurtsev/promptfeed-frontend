    /**
     * Ranking Algorithm
     * rank = (score / (age_in_hours + 2)^1.5) + boost_weight
     */
    calculateRank(prompt) {
        const score = prompt.upvotes - prompt.downvotes;
        const ageInHours = (Date.now() - new Date(prompt.createdAt).getTime()) / (1000 * 60 * 60);
        const gravity = 1.5;
        const boost = prompt.isBoosted ? (prompt.boostWeight || 20) : 0;

        return (score / Math.pow(ageInHours + 2, gravity)) + boost;
    }

    getFeed(filter = 'top', tag = null, searchQuery = null) {
        let sortedPrompts = [...this.prompts];

        // 1. Filter by Tag
        if (tag) {
            sortedPrompts = sortedPrompts.filter(p => p.tags.some(t => t.toLowerCase() === tag.toLowerCase()));
        }

        // 2. Filter by Search Query
        if (searchQuery) {
            const q = searchQuery.toLowerCase();
            sortedPrompts = sortedPrompts.filter(p =>
                p.title.toLowerCase().includes(q) ||
                p.description.toLowerCase().includes(q) ||
                p.tags.some(t => t.toLowerCase().includes(q))
            );
        }

        // 3. Sort
        if (filter === 'top') {
            sortedPrompts.sort((a, b) => this.calculateRank(b) - this.calculateRank(a));
        } else if (filter === 'new') {
            sortedPrompts.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
        } else if (filter === 'controversial') {
            sortedPrompts.sort((a, b) => (b.upvotes + b.downvotes) - (a.upvotes + a.downvotes));
        }

        return sortedPrompts.map(p => {
            const author = this.users.find(u => u.id === p.authorId);
            return {
                ...p,
                authorHandle: author ? author.handle : 'Unknown',
                rankScore: this.calculateRank(p).toFixed(2)
            };
        });
    }

    getUser(id) {
        return this.users.find(u => u.id === id);
    }

    getCurrentUser() {
        return this.currentUser;
    }

